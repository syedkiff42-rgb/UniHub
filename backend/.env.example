# ─── Server ───────────────────────────────
PORT=3000
NODE_ENV=development

# ─── MySQL (update to your XAMPP credentials) ─────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=unihub_db

# ─── JWT ──────────────────────────────────
JWT_SECRET=your_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_change_this
JWT_REFRESH_EXPIRES_IN=30d

# ─── File Upload ──────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads/pdfs

# ─── Moodle Integration (Module 4) ────────
# Leave blank to use dummy assignments until API access is granted
MOODLE_URL=
MOODLE_TOKEN=
