# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── MySQL ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=unihub

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# ── File uploads ──────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:8081,exp://localhost:8081